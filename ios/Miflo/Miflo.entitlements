<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>aps-environment</key>
	<string>development</string>
	<key>com.apple.developer.associated-domains</key>
	<array>
		<!-- No ?mode=developer: it requires Settings > Developer > Associated
		     Domains Development to be toggled on the device, and without that
		     toggle the association silently fails and links open in Safari. It
		     existed to skip Apple-CDN lag, but the CDN copy tracks miflo.dk
		     fine, so plain applinks is the safer default. Associations only
		     register at install time — reinstall after changing this. -->
		<string>applinks:miflo.dk</string>
		<string>applinks:www.miflo.dk</string>
	</array>
</dict>
</plist>
