+// A TurboModule callback is one-shot: the second call is LOG(FATAL) in
+// RCTTurboModule.mm, which aborts the process. The delegate paths here can
+// fire twice (a dismissal delegate racing the async asset load), so every
+// invocation goes through this and the second one is dropped.
+- (void)invokeCallbackOnce:(NSArray *)args
+{
+    RCTResponseSenderBlock callback = self.callback;
+    if (callback == nil) {
+        return;
+    }
+    self.callback = nil;
+    callback(args);
+}
